HRG_REDIS_URL=redis://127.0.0.1:6379/0
HRG_HOST=127.0.0.1
HRG_PORT=8788
HRG_API_KEY=

HRG_STREAM_KEY=hermes:stream:default
HRG_STREAM_GROUP=workers
HRG_STREAM_CONSUMER=worker-1
HRG_QUEUE_COUNT_KEY=hermes:queue:default:count
HRG_JOB_PREFIX=hermes:job:
HRG_SLOT_PREFIX=hermes:slot:
HRG_QUEUE_MAX_SIZE=100
HRG_SYNC_WAIT_TIMEOUT_SECONDS=180
HRG_JOB_TTL_SECONDS=86400

HRG_SLOT_COUNT=10
HRG_SLOT_LEASE_SECONDS=240
HRG_SLOT_ACQUIRE_TIMEOUT_SECONDS=30
HRG_WORKER_THREADS=10
HRG_WORKER_POLL_TIMEOUT_SECONDS=5

HRG_HERMES_PYTHON=/home/song/.hermes/hermes-agent/venv/bin/python
HRG_HERMES_PROVIDER=openai-codex
HRG_HERMES_MODEL=gpt-5.4-mini
HRG_HERMES_TOOLSETS=
HRG_ALLOWED_MODELS=gpt-5.4-mini,gpt-5.4
HRG_HERMES_TIMEOUT_SECONDS=180
HRG_MAX_PROMPT_BYTES=200000
HRG_MAX_WAIT_TIMEOUT_SECONDS=180
HRG_BASE_HERMES_HOME=/home/song/.hermes
HRG_SLOT_HOME_ROOT=/home/song/.hermes/hermes-redis-gateway-slots
HRG_SLOT_WORKDIR_ROOT=/tmp/hermes-redis-gateway-slots
HRG_SLOT_PROFILE_PREFIX=vlainter-stateless-llm
